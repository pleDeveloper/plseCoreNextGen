{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Pulse brand tokens — canonical source. Mirrors force-app/main/default/staticresources/pulse_brand_tokens.css. Keep in sync.",
  "version": "1.0.0",
  "asOf": "2026-04-21",
  "color": {
    "primary": {
      "pulsePurple":    { "$value": "#7B2FF2", "$type": "color", "$description": "Primary actions, links, focus states." },
      "purpleDark":     { "$value": "#5A1DB8", "$type": "color", "$description": "Hover states, active elements." },
      "pulseMagenta":   { "$value": "#D946EF", "$type": "color", "$description": "Gradient start, accents, highlights." }
    },
    "gradient": {
      "primary":        { "$value": "linear-gradient(135deg, #D946EF 0%, #7B2FF2 100%)", "$type": "gradient" },
      "primaryHover":   { "$value": "linear-gradient(135deg, #E068F5 0%, #8F47F5 100%)", "$type": "gradient" }
    },
    "neutral": {
      "dark":          { "$value": "#111827", "$type": "color" },
      "slateDark":     { "$value": "#374151", "$type": "color" },
      "slate":         { "$value": "#6B7280", "$type": "color" },
      "slateLight":    { "$value": "#9CA3AF", "$type": "color" },
      "border":        { "$value": "#E5E7EB", "$type": "color" },
      "lightGray":     { "$value": "#F3F4F6", "$type": "color" },
      "offWhite":      { "$value": "#F9FAFB", "$type": "color" },
      "white":         { "$value": "#FFFFFF", "$type": "color" }
    },
    "semantic": {
      "success":       { "$value": "#10B981", "$type": "color" },
      "warning":       { "$value": "#F59E0B", "$type": "color" },
      "error":         { "$value": "#EF4444", "$type": "color" },
      "info":          { "$value": "#3B82F6", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "primary":       { "$value": "Poppins, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" },
      "mono":          { "$value": "'SF Mono', 'Fira Code', 'Menlo', monospace" }
    },
    "size": {
      "caption":       { "$value": "12px" },
      "small":         { "$value": "14px" },
      "body":          { "$value": "16px" },
      "h4":            { "$value": "18px" },
      "h3":            { "$value": "24px" },
      "h2":            { "$value": "36px" },
      "h1":            { "$value": "48px" },
      "display":       { "$value": "56px" }
    },
    "weight": {
      "light":         { "$value": 300 },
      "regular":       { "$value": 400 },
      "medium":        { "$value": 500 },
      "semibold":      { "$value": 600 },
      "bold":          { "$value": 700 },
      "extrabold":     { "$value": 800, "$description": "Reserved for hero headlines only." }
    },
    "lineHeight": {
      "heading":       { "$value": 1.1 },
      "subheading":    { "$value": 1.3 },
      "label":         { "$value": 1.4 },
      "body":          { "$value": 1.7 }
    }
  },
  "spacing": {
    "1":  { "$value": "4px"  },
    "2":  { "$value": "8px"  },
    "3":  { "$value": "12px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "20": { "$value": "80px" }
  },
  "radius": {
    "sm":     { "$value": "6px"   },
    "md":     { "$value": "8px"   },
    "lg":     { "$value": "10px",  "$description": "Buttons." },
    "xl":     { "$value": "12px",  "$description": "Inputs, small cards." },
    "2xl":    { "$value": "16px",  "$description": "Cards, modals." },
    "pill":   { "$value": "100px", "$description": "Badges, tags." }
  },
  "shadow": {
    "sm":           { "$value": "0 1px 2px rgba(0, 0, 0, 0.04)" },
    "md":           { "$value": "0 4px 12px rgba(0, 0, 0, 0.06)" },
    "lg":           { "$value": "0 8px 32px rgba(0, 0, 0, 0.08)" },
    "purple":       { "$value": "0 4px 16px rgba(123, 47, 242, 0.25)" },
    "purpleHover":  { "$value": "0 6px 24px rgba(123, 47, 242, 0.35)" },
    "focusRing":    { "$value": "0 0 0 3px rgba(123, 47, 242, 0.1)" }
  },
  "motion": {
    "fast":   { "$value": "0.15s ease" },
    "base":   { "$value": "0.2s ease"  },
    "slow":   { "$value": "0.3s ease"  }
  },
  "component": {
    "button": {
      "primary": {
        "background":  "var(--pulse-gradient)",
        "color":       "var(--pulse-white)",
        "shadow":      "var(--pulse-shadow-purple)",
        "hoverTransform": "translateY(-1px)"
      },
      "secondary": {
        "background":  "var(--pulse-white)",
        "color":       "var(--pulse-purple)",
        "border":      "2px solid var(--pulse-purple)"
      },
      "dark": {
        "background":  "var(--pulse-dark)",
        "color":       "var(--pulse-white)"
      },
      "ghost": {
        "background":  "transparent",
        "color":       "var(--pulse-slate-dark)"
      }
    },
    "input": {
      "background":    "var(--pulse-white)",
      "border":        "1.5px solid var(--pulse-border)",
      "focusBorder":   "var(--pulse-purple)",
      "focusRing":     "var(--pulse-shadow-focus-ring)",
      "radius":        "var(--pulse-radius-lg)"
    },
    "card": {
      "background":    "var(--pulse-white)",
      "border":        "1px solid var(--pulse-border)",
      "radius":        "var(--pulse-radius-2xl)",
      "padding":       "var(--pulse-space-8)",
      "hoverShadow":   "var(--pulse-shadow-lg)",
      "hoverTransform":"translateY(-2px)"
    }
  },
  "voice": {
    "pillars": [
      "Seamless Integration — native, no middleware",
      "Automated Intelligence — data moves automatically",
      "Zero Friction Deployment — install and configure in minutes"
    ],
    "tone": {
      "formal": 0.75,
      "serious": 0.70,
      "bold": 0.40,
      "technical": 0.45
    },
    "writeThis":  [
      "Short, sequential sentences",
      "Concrete workflows, named platforms (Salesforce, Slack)",
      "Outcomes tied to pain points (pipeline hygiene, forecast accuracy)",
      "Sentence case for headings"
    ],
    "avoidThis": [
      "Buzzwords: synergy, unlock, unprecedented, innovative",
      "All-caps outside of labels/badges",
      "Generic SaaS claims that could describe any product",
      "Centered paragraphs longer than two lines"
    ]
  }
}
